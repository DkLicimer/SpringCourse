# ==================== НАСТРОЙКИ ПОЧТОВОГО СЕРВЕРА GMAIL (SMTP) ====================

# Адрес SMTP-сервера Google
EMAIL_HOST=smtp.gmail.com

# Порт для TLS-соединения (для Gmail строго 587)
EMAIL_PORT=587

# Отключаем SSL, так как используем TLS на порту 587
EMAIL_USE_SSL=False

# Включаем TLS шифрование (обязательно для Gmail)
EMAIL_USE_TLS=True

# Ваш созданный адрес почты Gmail (отправитель писем)
EMAIL_HOST_USER=zabgumanager@gmail.com

# Скопированный 16-значный пароль приложения (без пробелов)
EMAIL_HOST_PASSWORD=aipawyvzgiiedjhd

# Технический адрес отправителя (обычно совпадает с EMAIL_HOST_USER)
DEFAULT_FROM_EMAIL=zabgumanager@gmail.com