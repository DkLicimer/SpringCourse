# --- ПРИЛОЖЕНИЕ (Secrets) ---
# Никогда не коммить реальные пароли!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- BACKEND (Python/Django) ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/
# Локальная база данных (мы используем Postgres в докере, но sqlite может создаться локально)
db.sqlite3
db.sqlite3-journal
# Папка с загруженными чеками (они должны жить только на сервере)
backend/media/receipts/*
!backend/media/receipts/.gitkeep
# Результаты тестов
backend/voucher_test.pdf
backend/test_pdf_generation.py

# --- FRONTEND (Node/React) ---
frontend/node_modules/
frontend/dist/
frontend/build/
.eslintcache
.stylelintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- СИСТЕМНЫЕ ФАЙЛЫ ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*.swo

# --- IDE (VS Code, PyCharm) ---
.vscode/
.idea/
*.iml
*.iws
*.sublime-project
*.sublime-workspace

# --- DOCKER ---
# Если ты используешь локальные данные для докера, их тоже лучше игнорировать
.docker-data/